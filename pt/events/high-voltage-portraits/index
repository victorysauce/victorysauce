<script>
const images = [
  { src: '/images/Will-Bremridge-072A7028web.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Lifestyle-Photographer-London-Will-Bremridge-Amaroun.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Will-Bremridge-Jay-Johnson.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Will-Bremridge-M1A4465.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Will-Bremridge-M1A5817.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Will-Bremridge-09.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/_M1A6516-Edit.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/MJM-website.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/breeze-gif.webp', caption: 'Fotografia de Will Bremridge' },
  { src: '/images/Will-Bremridge-Skipping.webp', caption: 'Fotografia de Will Bremridge' },
];
let current = 0;
function openLightbox(idx) {
  current = idx;
  updateLightbox();
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}
function closeLightboxOutside(e) {
  if (e.target === document.getElementById('lightbox')) closeLightbox();
}
function updateLightbox() {
  document.getElementById('lightboxImg').src = images[current].src;
  document.getElementById('lightboxCaption').textContent = images[current].caption;
  document.getElementById('lightboxCounter').textContent = (current + 1) + ' / ' + images.length;
}
function nextImage(e) { e.stopPropagation(); current = (current + 1) % images.length; updateLightbox(); }
function prevImage(e) { e.stopPropagation(); current = (current - 1 + images.length) % images.length; updateLightbox(); }
document.addEventListener('keydown', function(e) {
  if (!document.getElementById('lightbox').classList.contains('open')) return;
  if (e.key === 'ArrowRight') { current = (current + 1) % images.length; updateLightbox(); }
  if (e.key === 'ArrowLeft') { current = (current - 1 + images.length) % images.length; updateLightbox(); }
  if (e.key === 'Escape') closeLightbox();
